{
  "name": "highlightjs-circom",
  "version": "1.0.2",
  "description": "Highlight.js syntax definition for the CIRCOM language",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/index.js",
    "dist/index.js.map",
    "dist/index.d.ts",
    "dist/index.d.ts.map",
    "src/index.ts",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc --project tsconfig.json --watch",
    "test": "npm run build && node --test dist/test/index.test.js",
    "lint": "tsc --project tsconfig.json --noEmit",
    "prepublishOnly": "npm run build && npm test",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "highlightjs",
    "highlight.js",
    "circom",
    "syntax-highlighting",
    "zero-knowledge",
    "zk-snark",
    "r1cs"
