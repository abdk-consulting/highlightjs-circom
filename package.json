  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/abdk-consulting/highlightjs-circom.git"
  },
  "bugs": {
    "url": "https://github.com/abdk-consulting/highlightjs-circom/issues"
  },
  "homepage": "https://github.com/abdk-consulting/highlightjs-circom#readme",
  "peerDependencies": {
    "highlight.js": ">=11.9.0"
  },
  "devDependencies": {
    "@types/node": "20.0.0",
    "highlight.js": "^11.11.1",
    "typescript": "6.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
